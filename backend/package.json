{
  "name": "yarnchem-erp-backend",
  "version": "1.0.0",
  "description": "YarnChem ERP Backend — GH & Sons Enterprises",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build-exe": "pkg . --target node18-win-x64 --output dist/yarnchem-backend.exe"
  },
  "pkg": {
    "assets": [
      "data/**/*",
      "config/**/*"
    ],
    "scripts": [
      "routes/**/*.js",
      "middlewares/**/*.js",
      "utils/**/*.js",
      "seed/**/*.js"
    ],
    "targets": ["node18-win-x64"]
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.3",
    "pkg": "^5.8.1"
  }
}